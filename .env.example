# Optional bootstrap settings.
# After the service starts, use http://localhost:8080 to configure the agent.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

WEB_PORT=8080
CONFIG_PATH=/data/config.json

# Initial schedule. Defaults to 08:30 Asia/Shanghai, every 1440 minutes.
TZ=Asia/Shanghai
SCHEDULE_TIME=08:30
SCHEDULE_INTERVAL_MINUTES=1440
TOP_N=10

# Initial email content options. Prefer filling these in on the web page.
BILINGUAL_EMAIL=true
INCLUDE_IMAGES=true
FETCH_ARTICLE_IMAGES=true

# Initial recipients. Comma-separated values are supported.
EMAIL_TO=swh_2018@126.com,customer@example.com

# Initial SMTP settings. Prefer filling these in on the web page.
# For 126.com as the sender, use the SMTP authorization code, not the normal
# mailbox login password.
SMTP_HOST=smtp.126.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_STARTTLS=false
SMTP_USERNAME=your_sender@126.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_sender@126.com

# Set true for a one-shot test run. Set false in long-running deployment.
RUN_ONCE=false

# Set true to print the email instead of sending it.
DRY_RUN=false

# Optional custom RSS feeds. Separate multiple feed URLs with commas.
# GLOBAL_FEEDS=https://news.google.com/rss?hl=zh-CN&gl=CN&ceid=CN:zh-Hans,https://news.google.com/rss/search?q=%E5%85%A8%E7%90%83%20%E7%83%AD%E7%82%B9%20when%3A1d&hl=zh-CN&gl=CN&ceid=CN:zh-Hans
# TECH_FEEDS=https://news.google.com/rss/headlines/section/topic/TECHNOLOGY?hl=zh-CN&gl=CN&ceid=CN:zh-Hans,https://news.google.com/rss/search?q=%E7%A7%91%E6%8A%80%20when%3A1d&hl=zh-CN&gl=CN&ceid=CN:zh-Hans
